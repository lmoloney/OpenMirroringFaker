# Open Mirroring Faker — Environment Variables
# Copy to .env and fill in your values
# .env is gitignored — never commit secrets

# ── Fabric OneLake ──
# Workspace ID: from Power BI URL /groups/<workspace-id>/
ONELAKE_WORKSPACE_ID=your-workspace-guid
# Mirrored DB ID: from Power BI URL /mirroreddatabases/<mirrored-db-id>/
ONELAKE_MIRRORED_DB_ID=your-mirrored-db-guid

# ── Logging ──
# LOG_LEVEL=INFO
